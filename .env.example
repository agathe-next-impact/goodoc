# =============================================================================
# MedSite — Example environment file
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` (git-ignored) and fill in real values.
# Every variable below is validated by Zod at startup — see
# `packages/config/src/env.ts`. Missing or malformed values will crash the
# process with a list of every issue.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# `development` | `production` | `test`
NODE_ENV=development
# Public-facing URL. Exposed to the browser — no secret here.
# Local dev: http://localhost:3003  |  Production: https://medsite.fr
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Public web origin used by Payload Live Preview to build the preview URL.
# In monorepo layouts this matches NEXT_PUBLIC_APP_URL but is kept distinct
# in case the public site moves to a different host.
NEXT_PUBLIC_WEB_URL=http://localhost:3003

# Origin allowed to iframe the public `/p/*` routes (Payload admin).
# Used to relax CSP `frame-ancestors` only on those paths.
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Shared secret for Payload Live Preview. Required as soon as the admin's
# preview panel is enabled. Generate with:  openssl rand -hex 32
PREVIEW_SECRET=

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16)
# -----------------------------------------------------------------------------
# Local:  postgresql://postgres:postgres@localhost:5432/medsite_dev
# Neon prod (POOLED — used by the app):
#   postgresql://user:pass@ep-xxx-pooler.<region>.aws.neon.tech/medsite?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medsite_dev

# Neon only — DIRECT (unpooled) endpoint, used exclusively by `pnpm db:migrate`
# and `psql < packages/db/rls.sql`. Never use this from the running app.
# DATABASE_MIGRATE_URL=postgresql://user:pass@ep-xxx.<region>.aws.neon.tech/medsite?sslmode=require

# -----------------------------------------------------------------------------
# Payload CMS
# -----------------------------------------------------------------------------
# Must be >= 32 chars. Generate with:  openssl rand -hex 32
# NEVER reuse between environments — rotating this invalidates every admin session.
PAYLOAD_SECRET=replace-with-openssl-rand-hex-32-output-here

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Test keys (sk_test_... / whsec_...) in dev, live keys (sk_live_...) in prod.
# Webhook secret is obtained when creating the webhook endpoint in Stripe.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
# Domain `medsite.fr` must be verified in Resend (SPF/DKIM/DMARC) before prod use.
RESEND_API_KEY=re_replace_me

# -----------------------------------------------------------------------------
# Cloudflare R2 (media storage)
# -----------------------------------------------------------------------------
# Create a scoped-bucket API token in R2 → "Manage R2 API Tokens".
CLOUDFLARE_R2_ACCESS_KEY=replace_me
CLOUDFLARE_R2_SECRET_KEY=replace_me
CLOUDFLARE_R2_BUCKET=medsite-media
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# Custom public domain mapped to the bucket (images are served from here).
CLOUDFLARE_R2_PUBLIC_URL=https://media.medsite.fr

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# Plausible analytics API key (only needed if analytics package is enabled).
PLAUSIBLE_API_KEY=

# Required as soon as cron endpoints (trial-expiry, payment-retry) are exposed.
# Generate with:  openssl rand -hex 32
# Vercel Cron automatically sends `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
