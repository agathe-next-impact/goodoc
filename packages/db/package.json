{
  "name": "@medsite/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./zod": "./src/zod/index.ts"
  },
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --env-file-if-exists=../../.env.local src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rimraf .turbo dist drizzle"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.4",
    "drizzle-zod": "^0.6.1",
    "postgres": "^3.4.5",
    "uuidv7": "^1.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@medsite/config": "workspace:*",
    "@medsite/templates": "workspace:*",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
